// RUN: solc --mlir-action=print-init %s | FileCheck %s

contract C {
  uint[] sa;
  uint[] sb;

  // Local storage ref .slot rewrite -> yul.storage_slot.
  function slotRewrite() public returns (uint) {
    sa.push(1);
    sb.push(2);
    uint[] storage p = sa;
    assembly { p.slot := sb.slot }
    return p[0];
  }

  // Memory ref whole-value rewrite -> yul.ptr_cast on the Memory-located alloca.
  function memRewrite() public pure returns (uint) {
    bytes memory a = hex"aa";
    bytes memory b = hex"bbcc";
    assembly { a := b }
    return a.length;
  }
}
