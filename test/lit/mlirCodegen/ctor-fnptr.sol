contract C {
  function(uint256) internal returns (uint256) x;
  uint256 y;

  constructor() {
    x = double;
    y = x(21);
  }

  function double(uint256 a) public returns (uint256) {
    return a * 2;
  }

  function use(uint256 a) public returns (uint256) {
    return x(a);
  }
}
