// Mutually recursive structs (A refers to B and B refers to A).
pragma solidity ^0.8.0;

contract C {
  struct A { uint256 av; B[] bs; }
  struct B { uint256 bv; A[] as_; }
  A a;
  function del() public {
    delete a;
  }
  function copyToMem() public view returns (uint256) {
    A memory m = a;
    return m.av;
  }
}
