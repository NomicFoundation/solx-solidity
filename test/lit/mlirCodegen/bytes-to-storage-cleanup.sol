// RUN: solc --mlir-action=print-init --mmlir --mlir-print-debuginfo %s | FileCheck %s

// Tests three cleanup scenarios when copying bytes to storage:
//
// 1. new_after_event: sol.malloc for new bytes(N) must carry zero_init so that
//    stale data written by event ABI encoding (which reuses the same scratch
//    region without advancing the free pointer) cannot leak into storage.
//
// 2. dirty_past_end: a byte written at offset (length) inside the last
//    32-byte word via inline assembly must not appear in storage; the partial
//    last slot must be masked before the store.
//
// 3. calldata_to_storage: calldata bytes whose final ABI word carries dirty
//    high bits beyond the declared length must be masked before storing;
//    s.push() must extend cleanly.

contract C {
    event Ev(uint[], uint);
    bytes public s;

    function new_after_event() external returns (bytes memory) {
        uint[] memory x = new uint[](2);
        emit Ev(x, 0x21);
        bytes memory m = new bytes(63);
        s = m;
        s.push();
        return s;
    }

    function dirty_past_end() external returns (bytes memory) {
        bytes memory m = new bytes(63);
        assembly {
            mstore8(add(m, add(32, 63)), 0x42)
        }
        s = m;
        s.push();
        return s;
    }

    function calldata_to_storage(bytes calldata c) external returns (bytes memory) {
        s = c;
        s.push();
        return s;
    }
}
