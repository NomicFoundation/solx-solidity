// RUN: solc --mlir-action=print-init --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
    struct WithBytes { uint256 x; bytes b; uint256 y; }
    struct WithString { uint256 x; string s; uint256 y; }

    // Zero-init: bytes/string pointer fields must be initialized to zeroPointer (0x60).
    function zero_bytes() public pure returns (uint256, uint256) {
        WithBytes memory wb;
        return (wb.x, wb.y);
    }

    function zero_string() public pure returns (uint256, uint256) {
        WithString memory ws;
        return (ws.x, ws.y);
    }

    // Literal construction: all fields written explicitly.
    function literal_bytes() public pure returns (uint256, uint256, uint256) {
        WithBytes memory wb = WithBytes({x: 1, b: "hello", y: 2});
        return (wb.x, wb.b.length, wb.y);
    }
}
