// RUN: solc --strict-assembly --mlir-action=print-init --mmlir --mlir-print-debuginfo %s | FileCheck %s

object "Test" {
  code {
    if callvalue() {
      mstore(0, 42)
    }
    return(0, 0)
  }
  object "Test_deployed" {
    code {
      if callvalue() {
        mstore(1, 42)
      }
      return(0, 0)
    }
  }
}

