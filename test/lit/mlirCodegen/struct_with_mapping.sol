// RUN: solc --mlir-action=print-init --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
  struct Data {
    uint a;
    mapping(uint => uint) m;
    uint b;
  }

  Data data;

  function set(uint key, uint val) public {
    data.a = 1;
    data.m[key] = val;
    data.b = 2;
  }

  function get(uint key) public view returns (uint, uint, uint) {
    return (data.a, data.m[key], data.b);
  }
}
