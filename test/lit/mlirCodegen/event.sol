// RUN: solc --mlir-action=print-init --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
  struct S { uint x; bool y; }

  event V(bool indexed);                       // value-type indexed
  event R(string indexed);                     // reference-type indexed (keccak path)
  event N(S);                                  // non-indexed struct (ABI tuple encoder)
  event Anon(uint indexed) anonymous;          // anonymous event (no signature topic)
  event Mixed(uint indexed i, string s);       // indexed + non-indexed

  function emitV(bool b) public { emit V(b); }
  function emitR(string memory s) public { emit R(s); }
  function emitN(uint x, bool y) public { emit N(S(x, y)); }
  function emitAnon(uint a) public { emit Anon(a); }
  function emitMixed(uint i, string memory s) public { emit Mixed(i, s); }
}
