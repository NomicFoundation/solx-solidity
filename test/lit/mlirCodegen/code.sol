// RUN: solc --mlir-action=print-init --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
  function f() public returns (uint) { return 42; }
}

contract D {
  function g() public returns (bytes memory) {
    C c1 = new C();
    C c2 = c1;
    return address(c2).code;
  }
  function h() public returns (bytes32) {
    C c = new C();
    return address(c).codehash;
  }
  function g_payable(address payable a) public view returns (bytes memory) {
    return a.code;
  }
  function h_payable(address payable a) public view returns (bytes32) {
    return a.codehash;
  }
}

