// RUN: solc --strict-assembly --mlir-action=print-init --mmlir --mlir-print-debuginfo %s | FileCheck %s

object "Test" {
  code {
    function no_ret() {}

    function ret() -> r {
      r := 42
    }

    function ret2() -> x, y {
      x := 42
      y := 43
    }

    let a := ret()
    let x, y := ret2()
    no_ret()
  }
}

