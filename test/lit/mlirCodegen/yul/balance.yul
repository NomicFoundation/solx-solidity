// CHECK-NEXT:   yul.object @Test {
// CHECK-NEXT:     %c0_i256 = yul.constant 0 loc(#loc1)
// CHECK-NEXT:     %0 = yul.balance %c0_i256 loc(#loc2)
// CHECK-NEXT:     %1 = yul.alloca : !yul.ptr loc(#loc3)
// CHECK-NEXT:     yul.store %0, %1 : i256, !yul.ptr loc(#loc4)
// CHECK-NEXT:   } loc(#loc)
// CHECK-NEXT: } loc(#loc)
// CHECK-NEXT: #loc = loc(unknown)
// CHECK-NEXT: #loc1 = loc({{.*}}:4:21)
// CHECK-NEXT: #loc2 = loc({{.*}}:4:13)
