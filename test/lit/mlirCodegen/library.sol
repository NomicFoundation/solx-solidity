function ff() returns(uint) { return L.f(1); }

library L {
  function f(uint a) internal returns(uint) { return a + 1; }
  function g(uint a) public returns(uint) { return f(a) + ff(); }
}

contract C {
  using L for uint;
  function f() public returns(uint) { return L.f(1); }
  function h(uint a) public returns(uint) { return a.g(); }
}

