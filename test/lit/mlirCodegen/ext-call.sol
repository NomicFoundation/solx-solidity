// RUN: solc --mlir-action=print-init --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
  function f(uint a) public payable returns(uint) {
    a = this.f(a);
    return this.f{value: 7, gas: a}(a);
  }
}

contract D {
  function g(address a) public returns (uint) {
    return C(a).f(1);
  }
}

