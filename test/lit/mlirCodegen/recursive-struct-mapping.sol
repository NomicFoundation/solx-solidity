pragma solidity ^0.8.0;

// Recursion through a mapping member (the cycle crosses a mapping boundary).

contract C {
  struct S {
    uint32 z;
    mapping(uint8 => S) rec;
  }

  S data;

  function set() public {
    data.z = 2;
    S storage inner = data.rec[0];
    inner.z = 3;
  }

  function del() public {
    delete data;
  }
}
