contract C {
  struct S {
    uint256 x;
    mapping(uint256 => uint256) m;
  }
  S s;
  mapping(uint256 => uint256) m;

  function del() public {
    delete s;
  }

  function get() internal view returns (mapping(uint256 => uint256) storage r) {
    r = m;
  }

  function useGet(uint256 k) public view returns (uint256) {
    return get()[k];
  }
}
