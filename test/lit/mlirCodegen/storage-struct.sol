// RUN: solc --mlir-action=print-init --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
  // Packed struct
  struct Packed {
    uint8 a;
    uint8 b;
    uint16 c;
  }
  Packed packed;

  // Non-packed struct
  struct NonPacked {
    uint256 x;
    uint256 y;
  }
  NonPacked nonPacked;

  // Nested struct
  struct Inner {
    uint8 x;
    uint8 y;
  }
  struct Outer {
    Inner inner;
    uint8 z;
  }
  Outer nested;

  // Mixed struct (value + reference types)
  struct Mixed {
    uint8 x;
    uint256[] arr;
    uint8 y;
  }
  Mixed mixed;

  // Struct with contract-typed field
  struct ContractRef {
    uint96 x;
    C c;
  }
  ContractRef contractRef;

  // Nested struct where inner has a dynamic member.
  struct InnerDynamic {
    uint256 a;
    uint128 b;
    string note;
  }
  struct OuterDynamic {
    uint256 left;
    InnerDynamic inner;
    uint256 right;
  }
  OuterDynamic nestedDynamic;

  function rw() public {
    packed.a = packed.b;
    nonPacked.x = nonPacked.y;
    nested.inner.x = nested.z;
    mixed.x = mixed.y;
    mixed.arr.push(1);
    contractRef.x = contractRef.x;
    contractRef.c = C(address(this));
    nestedDynamic.left = 100;
    nestedDynamic.inner.a = 201;
    nestedDynamic.inner.b = 202;
    nestedDynamic.inner.note = "in";
    nestedDynamic.right = 300;
    nestedDynamic.inner.a = nestedDynamic.right;
  }
}
