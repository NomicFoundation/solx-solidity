// RUN: solc --mlir-action=print-init --mmlir --mlir-print-debuginfo %s | FileCheck %s

library L {
  struct S {
    uint x;
    uint y;
  }

  function f(uint[] storage r, S storage s)
    external
    view
    returns (uint, uint, uint, uint)
  {
    return (r[0], r[1], s.x, s.y);
  }
}

contract C {
  L.S s;
  uint[] r;

  function g() external view returns (uint, uint, uint, uint) {
    return L.f(r, s);
  }
}
