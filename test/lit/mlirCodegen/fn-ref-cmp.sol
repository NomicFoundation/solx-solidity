// RUN: solc --mlir-action=print-init --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract Helper {
    function a() external pure returns (uint) { return 1; }
    function b() external pure returns (uint) { return 2; }
}

contract C {
    function() external pure returns (uint) stored;

    function f() external pure returns (uint) { return 10; }
    function g() external pure returns (uint) { return 20; }

    function eq_same() public returns (bool) {
        return this.f == this.f;
    }

    function neq_diff_sel() public returns (bool) {
        return this.f != this.g;
    }

    function eq_stored() public returns (bool) {
        stored = this.f;
        return stored == this.f;
    }

    function neq_diff_addr() public returns (bool) {
        Helper h1 = new Helper();
        Helper h2 = new Helper();
        return h1.a != h2.a;
    }
}
