// RUN: solc --mlir-action=print-init --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
  uint u1;
  uint u2;
  uint u3;

  uint[2] fa1;
  uint[2] fa2;

  uint[] da1;
  uint[] da2;

  function scalar3(uint v) public { u1 = u2 = u3 = v; }

  function local2(uint v) public pure returns (uint, uint) {
    uint la1;
    uint la2;
    la1 = la2 = v;
    return (la1, la2);
  }

  function fixedArr(uint[2] memory src) public { fa1 = fa2 = src; }

  function dynArr(uint[] memory src) public { da1 = da2 = src; }
}
