// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
  bool s0;
  bool[] s1;

  function mem_bool(bool[] memory x) public returns (bool) {
    return x[0];
  }

  function storage_bool() public view returns (bool) {
    return s0;
  }

  function storage_array_bool() public view returns (bool) {
    return s1[0];
  }

  function encode_array_bool(bool[] memory x) public returns (bytes memory) {
    return abi.encode(x);
  }

  function encode_packed_array_bool(bool[] memory x) public returns (bytes memory) {
    return abi.encodePacked(x);
  }

  function decode_bool(bytes memory x) public pure returns (bool) {
    return abi.decode(x, (bool));
  }
}
