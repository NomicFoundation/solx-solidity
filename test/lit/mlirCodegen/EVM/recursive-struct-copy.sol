// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s
pragma solidity ^0.8.0;

contract C {
  struct S {
    uint256 a;
    S[] b;
  }

  S s1;
  S s2;

  function copyStoToSto() public {
    s2 = s1;
  }

  function copyStoToMem() public view returns (uint256) {
    S memory m = s1;
    return m.a;
  }

  function copyMemToSto() public {
    S memory m;
    m.a = 1;
    m.b = new S[](2);
    s1 = m;
  }
}
