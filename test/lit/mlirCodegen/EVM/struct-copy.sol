// SPDX-License-Identifier: MIT
pragma solidity ^0.8.0;
enum Direction { North, South, East, West }

struct Inner {
    int72        a;
    uint8        b;
    bool[][]     flags;
    address[2]   fixedAddrArr;
    int192       d;
    uint8        e;
    bytes4       f;
}

struct C {
    uint8        a;
    bytes19      b;
    uint72[7]    n;
    Inner[3]     c;
    string       d;
    uint[]       e;
    uint         f;
    uint224      f2;
    bool         g;
    Direction    h;
    Inner        i;
    address[2]   j;
    Inner[][]    l;
    uint192[5]   m;
    int192[5]    o;
    int72[7]     p;
    bytes        q;
    bytes8[5]    r;
    int16[9]     s;
    uint128[3]   t;
    int128[3]    u;
    bool[5]      v;
    bytes32      w;
    int          x;
    address[]    y;
    int8         z;
    uint8[33]    aa;
}

contract Test {
  C c1;
  C c2;

  function f1() public {
    c1 = c2;
  }

  function f2(C memory src) public {
    c1 = src;
  }

  function f3(C calldata src) public {
    c1 = src;
  }

  function f4() public returns(C memory){
    return c1;
  }

  function f5(C calldata src) public returns(C memory){
    return src;
  }
}
