// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s

enum E { A, B, C }

contract C {
  uint256 transient a;
  uint8 transient b;
  bytes4 transient c;
  address transient d;
  int8 transient e;
  E transient f;
  bool transient g;

  function test(bytes4 b4, address addr, E ev) public returns (uint256, uint8, bytes4, address, int8, E, bool) {
    a = 1;
    b = 2;
    c = b4;
    d = addr;
    e = -10;
    f = ev;
    g = true;
    return (a, b, c, d, e, f, g);
  }
}

