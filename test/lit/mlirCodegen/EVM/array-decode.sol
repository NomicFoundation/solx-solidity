// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
  function decode(uint8[] memory x) public returns (uint8) {
    return x[0];
  }

  function array_fixed(bytes memory data) external pure returns (uint256) {
    abi.decode(data, (uint256[2]));
    return 0;
  }

  function array_dyn(bytes memory data) external pure returns (uint256) {
    abi.decode(data, (uint256[]));
    return 0;
  }

  function array_fixed_fixed(bytes memory data) external pure returns (uint256) {
    abi.decode(data, (uint256[2][2]));
    return 0;
  }

  function array_dyn_dyn(bytes memory data) external pure returns (uint256) {
    abi.decode(data, (uint256[][]));
    return 0;
  }

  function array_fixed_dyn(bytes memory data) external pure returns (uint256) {
    abi.decode(data, (uint256[2][]));
    return 0;
  }

  function array_dyn_fixed(bytes memory data) external pure returns (uint256) {
    abi.decode(data, (uint256[][2]));
    return 0;
  }

  function string_fixed(bytes memory data) external pure returns (uint256) {
    abi.decode(data, (string[2]));
    return 0;
  }

  function string_dyn(bytes memory data) external pure returns (uint256) {
    abi.decode(data, (string[]));
    return 0;
  }

  function string_fixed_fixed(bytes memory data) external pure returns (uint256) {
    abi.decode(data, (string[2][2]));
    return 0;
  }

  function string_dyn_dyn(bytes memory data) external pure returns (uint256) {
    abi.decode(data, (string[][]));
    return 0;
  }

  function string_fixed_dyn(bytes memory data) external pure returns (uint256) {
    abi.decode(data, (string[2][]));
    return 0;
  }

  function string_dyn_fixed(bytes memory data) external pure returns (uint256) {
    abi.decode(data, (string[][2]));
    return 0;
  }
}
