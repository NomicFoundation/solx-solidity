// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s
pragma solidity ^0.8.0;

contract ArrayCopyPacked {
    uint8[33]  su8s_a;
    uint8[]    su8d_a;
    uint8[]    su8d_b;
    bytes3[5]  sb3s_a;
    bytes3[]   sb3d;
    bytes16[3] sb16s;
    bytes16[]  sb16d_a;
    bytes17[3] sb17s;
    bytes17[]  sb17d_a;
    bytes17[]  sb17d_b;
    address[2] sadds;

    function m2s_u8s(uint8[33] memory src) public { su8s_a = src; }
    function m2s_b16d(bytes16[] memory src) public { sb16d_a = src; }
    function s2m_b3s() public view returns (bytes3[5] memory) { return sb3s_a; }
    function s2m_b16d() public view returns (bytes16[] memory) { return sb16d_a; }
    function cd2s_b3s(bytes3[5] calldata src) external { sb3s_a = src; }
    function cd2m_b16s(bytes16[3] calldata src) external pure returns (bytes16[3] memory) { return src; }
    function s2s_b3() public { sb3d = sb3s_a; }
    function s2s_b17d() public { sb17d_b = sb17d_a; }
    function m2s_b17s(bytes17[3] memory src) public { sb17s = src; }
    function cd2m_b17s(bytes17[3] calldata src) external pure returns (bytes17[3] memory) { return src; }
    function cd2m_addr(address[2] calldata src) external pure returns (address[2] memory) { return src; }
}
