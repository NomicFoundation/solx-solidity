contract C {
  function f_uint() public returns (uint a) { a = 1; }

  function f_zero() public returns (uint a) {}

  function f_multi() public returns (uint a, uint b) { a = 10; b = 20; }

  function f_bool() public returns (bool ok) { ok = true; }

  function f_cond(bool flag) public returns (uint r) {
    if (flag) { r = 1; } else { r = 2; }
  }

  function f_noname(uint b) public returns (uint a) { return b; }
}
