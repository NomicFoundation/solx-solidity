contract C {
    uint256[][3][]  dynInFixed;
    string[2][]     strInFixed;

    struct Inner {
        uint256 v;
        uint256[] data;
    }

    Inner[2][]  fixedOfStruct;

    struct S {
        uint256 x;
        uint256[][2] data;
    }

    S[] structWithFixed;

    function popDynInFixed()      public { dynInFixed.pop(); }
    function popStrInFixed()      public { strInFixed.pop(); }
    function popFixedOfStruct()   public { fixedOfStruct.pop(); }
    function popStructWithFixed() public { structWithFixed.pop(); }
}
