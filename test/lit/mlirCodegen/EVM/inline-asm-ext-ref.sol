// RUN: solc --mlir-target=evm --mlir-action=print-std-mlir %s | FileCheck %s

contract C {
  uint[] sa;
  uint[] sb;

  function slotRewrite() public returns (uint) {
    sa.push(1);
    sb.push(2);
    uint[] storage p = sa;
    assembly { p.slot := sb.slot }
    return p[0];
  }

  function memRewrite() public pure returns (uint) {
    bytes memory a = hex"aa";
    bytes memory b = hex"bbcc";
    assembly { a := b }
    return a.length;
  }

  function fn() external {}

  function extFuncMembers() public view returns (uint a, uint s) {
    function() external f = this.fn;
    assembly {
      a := f.address
      s := f.selector
      f.address := 0xdead
      f.selector := 0xbeef
    }
  }

  uint constant CON = 42;

  // Constant reference -> yul.val_cast of the materialized value.
  function constantRef() public pure returns (uint w) {
    assembly { w := CON }
  }

  // Calldata dyn ref .offset / .length read+write via yul.calldata_offset /
  // yul.calldata_length bridges on the {addr, size} stack alloca.
  function calldataMembers(bytes calldata d) public pure returns (uint o, uint l) {
    assembly {
      o := d.offset
      l := d.length
      d.offset := add(o, 0x20)
      d.length := sub(l, 1)
    }
  }

  // Local storage ref .offset (always 0, RO) -> yul.storage_offset.
  function storageOffset() public returns (uint o) {
    uint[] storage p = sa;
    assembly { o := p.offset }
  }
}
