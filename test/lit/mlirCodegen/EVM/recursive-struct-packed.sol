// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s
pragma solidity ^0.8.0;

contract C {
  struct S {
    uint16 v;
    uint32 w;
    S[] x;
  }

  S s1;
  S s2;

  function copySto() public {
    s2 = s1;
  }

  function copyMem() public view returns (uint16, uint32) {
    S memory m = s1;
    return (m.v, m.w);
  }
}
