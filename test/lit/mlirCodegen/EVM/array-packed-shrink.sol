// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s
pragma solidity ^0.8.0;

contract ArrayPackedShrink {
    bytes16[] sb16d;
    uint8[]   su8d;
    uint16[]  su16d;

    function shrink_b16(bytes16[] memory full, bytes16[] memory shortened) public {
        sb16d = full;
        sb16d = shortened;
    }
    function shrink_u8(uint8[] memory full, uint8[] memory shortened) public {
        su8d = full;
        su8d = shortened;
    }
    function shrink_u16(uint16[] memory full, uint16[] memory shortened) public {
        su16d = full;
        su16d = shortened;
    }
}
