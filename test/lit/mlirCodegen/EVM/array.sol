// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s

function ui_1d(uint256[3] memory a, uint256 i) returns (uint256) {
  return a[i];
}
function ui_2d(uint256[3][4] memory a, uint256 i) returns (uint256) {
  return a[i][i];
}
function ui32_1d(uint32[3] memory a, uint i) {
  a[0] = a[i];
}

function malloc_1d() {
  uint256[3] memory a;
}
function malloc_2d() {
  uint256[3][4] memory a;
}
function new_1d() returns (uint) {
  uint[] memory a;
  a = new uint[](5);
  a[0] = 1;
  return a[0];
}
function new_2d() returns (uint) {
    uint[][] memory a;
    a = new uint[][](2);
    a[0] = new uint[](2);
    a[1] = new uint[](2);
    a[0][1] = 1;
    return a[0][1];
}

function len() returns (uint, uint) {
  uint[] memory a;
  a = new uint[](2);
  uint[3] memory b;
  return (a.length, b.length);
}

function lit() returns (uint[2] memory) {
  uint b = 2;
  uint[2] memory a = [uint256(1), b];

  return a;
}
function lit_2d() {
  uint[2][2] memory a = [[uint(10), uint(11)], [uint(20), uint(21)]];
}

function cd_arr(uint[] calldata a) returns (uint, uint) {
  return (a.length, a[0]);
}

function cd_named_ret_arr(uint[] calldata a) returns (uint[] calldata s) {
  s = a;
}

function cd_named_ret_str(bytes calldata a) returns (bytes calldata s) {
  s = a;
}

function stg_arr(uint[] storage a) returns (uint, uint) {
  return (a.length, a[0]);
}

