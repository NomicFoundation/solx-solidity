// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
  function array_encode(uint256[][2] calldata x) external pure returns (bytes memory) {
    return abi.encode(x);
  }

  function array_dyn_encode(uint256[][] calldata x) external pure returns (bytes memory) {
    return abi.encode(x);
  }

  function array_nested_encode(uint256[][2][] calldata x) external pure returns (bytes memory) {
    return abi.encode(x);
  }
}
