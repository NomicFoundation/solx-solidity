// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
  struct Static { uint a; uint16 b; bool c; }
  struct Dynamic { uint a; string s; bool c; }
  event EStatic(Static indexed s);
  event EDynamic(Dynamic indexed s);

  function emitStatic(uint a, uint16 b, bool c) public {
    emit EStatic(Static(a, b, c));
  }

  function emitDynamic(uint a, string memory s, bool c) public {
    emit EDynamic(Dynamic(a, s, c));
  }
}
