// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
  uint ui;
  address addr;
  mapping(address => uint) m0;
  mapping(address => mapping(address => uint256)) m1;
  mapping(C => uint) mc0;
  mapping(uint => C) mc1;
  string s;

  function get_ui() private returns (uint) { return ui; }
  function get_addr() private returns (address) { return addr; }
  function get_m0(address a) private returns (uint) { return m0[a]; }
  function get_m1(address a, address b) private returns (uint) { return m1[a][b]; }
  function get_mc0(C a) private returns (uint) { return mc0[a]; }
  function set_mc0(C a, uint v) private { mc0[a] = v; }
  function get_mc1(uint a) private returns (C) { return mc1[a]; }
  function set_mc1(uint a, C b) private { mc1[a] = b; }
  function get_s() private returns (string memory) { return s; }

  function set_addr(address a) private { addr = a; }
  function set_s(string memory a) private { s = a; }
}

