// RUN: solc --mlir-action=print-std-mlir --mmlir --mlir-print-debuginfo %s | FileCheck %s

type Price is uint128;

function wrap_price(uint128 x) pure returns (Price) {
  return Price.wrap(x);
}

function unwrap_price(Price p) pure returns (uint128) {
  return Price.unwrap(p);
}

using {add as +} for Price global;

function add(Price a, Price b) pure returns (Price) {
  return Price.wrap(Price.unwrap(a) + Price.unwrap(b));
}

function use_operator(Price a, Price b) pure returns (Price) {
  return a + b;
}

