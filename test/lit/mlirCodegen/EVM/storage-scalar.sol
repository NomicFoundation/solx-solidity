// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
  // Packed in slot 0
  uint8 a;
  uint8 b;
  uint16 c;

  // New slot 1
  uint256 d;

  // Packed in slot 2
  bytes4 e;
  bytes4 f;
  address g;

  function rw() public {
    a = a;
    b = b;
    c = c;
    d = d;
    e = e;
    f = f;
    g = g;
  }
}

