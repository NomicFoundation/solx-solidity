// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s

enum Color { Red, Green, Blue }

contract C {
  mapping(uint => uint) m_uint;
  mapping(address => uint) m_addr;
  mapping(Color => uint) m_enum;
  mapping(bytes4 => uint) m_bytes4;
  mapping(string => uint) m_string;
  string s;

  function get_uint(uint k) public view returns (uint) {
    return m_uint[k];
  }

  function set_uint(uint k, uint v) public {
    m_uint[k] = v;
  }

  function get_addr(address k) public view returns (uint) {
    return m_addr[k];
  }

  function get_enum(Color k) public view returns (uint) {
    return m_enum[k];
  }

  function get_bytes4(bytes4 k) public view returns (uint) {
    return m_bytes4[k];
  }

  function get_string(string calldata k) public view returns (uint) {
    return m_string[k];
  }

  function set_string(string memory k, uint v) public {
    m_string[k] = v;
  }

  function get_string_storage() public view returns (uint) {
    return m_string[s];
  }
}
