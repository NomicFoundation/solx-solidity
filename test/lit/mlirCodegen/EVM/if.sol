// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s

function if_else(uint a, uint b) {
  uint c;
  if (a == b)
    c = a;
  else
    c = b;
}

function tern_uint(bool c, uint a, uint b) returns (uint) {
  return c ? a : b;
}

function tern_bytes4(bool c, bytes4 a, bytes4 b) returns (bytes4) {
  return c ? a : b;
}

function tern_tuple(bool c, uint a, uint b, uint x, uint y) returns (uint, uint) {
  return c ? (a, b) : (x, y);
}

function tern_const(bool c) returns (uint) {
  return c ? 1 : 2;
}

