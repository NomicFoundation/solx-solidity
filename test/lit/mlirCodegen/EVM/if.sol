function f(uint a, uint b) {
  uint c;
  if (a == b)
    c = a;
  else
    c = b;
}

function g(bool c, uint a, uint b) returns (uint) {
  return c ? a : b;
}

function h(bool c, bytes4 a, bytes4 b) returns (bytes4) {
  return c ? a : b;
}

