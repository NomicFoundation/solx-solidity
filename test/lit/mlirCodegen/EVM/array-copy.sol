// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm %s | FileCheck %s

contract ArrayCopy {
    uint256[3] ss;
    uint256[]  sd;

    uint256[3][2] ss2;
    uint256[][]   sd2;

    string str;

    function m2s_stat(uint256[3] memory src) public { ss = src; }
    function m2s_dyn(uint256[] memory src) public { sd = src; }
    function s2m_stat() public view returns (uint256[3] memory) { return ss; }
    function s2m_dyn() public view returns (uint256[] memory) { return sd; }
    function cd2m_stat(uint256[3] calldata src) external pure returns (uint256[3] memory) { return src; }
    function cd2m_dyn(uint256[] calldata src) external pure returns (uint256[] memory) { return src; }

    function m2s_stat2d(uint256[3][2] memory src) public { ss2 = src; }
    function m2s_dyn2d(uint256[][] memory src) public { sd2 = src; }
    function s2m_stat2d() public view returns (uint256[3][2] memory) { return ss2; }
    function s2m_dyn2d() public view returns (uint256[][] memory) { return sd2; }
    function cd2m_stat2d(uint256[3][2] calldata src) external pure returns (uint256[3][2] memory) { return src; }
    function cd2m_dyn2d(uint256[][] calldata src) external pure returns (uint256[][] memory) { return src; }

    function m2s_str(string memory src) public { str = src; }
    function s2m_str() public view returns (string memory) { return str; }
    function cd2m_str(string calldata src) external pure returns (string memory) { return src; }
}
