contract C {
  enum E { A, B, C }

  function add(uint a, uint b) external pure returns (uint) {
    return a + b;
  }

  function loadMemoryByte(bytes memory data) external pure returns (bytes1) {
    return data[0];
  }

  function storeMemoryByte(bytes memory data, bytes1 value) external pure{
    data[0] = value;
  }

  function loadMemoryBool(bool[] memory values) external pure returns (bool) {
    return values[0];
  }

  function storeMemoryBool(bool[] memory values, bool value) external pure {
    values[0] = value;
  }

  function loadMemoryUint8(uint8[] memory values) external pure returns (uint8) {
    return values[0];
  }

  function storeMemoryUint8(uint8[] memory values, uint8 value) external pure {
    values[0] = value;
  }

  function loadMemoryInt8(int8[] memory values) external pure returns (int8) {
    return values[0];
  }

  function storeMemoryInt8(int8[] memory values, int8 value) external pure {
    values[0] = value;
  }

  function loadMemoryEnum(E[] memory values) external pure returns (uint8) {
    return uint8(values[0]);
  }

  function discardMemoryEnum(E[] memory values) external pure returns (uint8) {
    values[0];
    return 1;
  }

  function storeMemoryEnum(E[] memory values, E value) external pure {
    values[0] = value;
  }

  function loadMemoryAddress(address[] memory values) external pure returns (address) {
    return values[0];
  }

  function storeMemoryAddress(address[] memory values, address value) external pure {
    values[0] = value;
  }

  function loadMemoryBytes4(bytes4[] memory values) external pure returns (bytes4) {
    return values[0];
  }

  function storeMemoryBytes4(bytes4[] memory values, bytes4 value) external pure {
    values[0] = value;
  }

  function loadMemoryBytes31(bytes31[] memory values) external pure returns (bytes31) {
    return values[0];
  }

  function storeMemoryBytes31(bytes31[] memory values, bytes31 value) external pure {
    values[0] = value;
  }

  function loadMemoryFnPtrHelper(function(uint, uint) external pure returns (uint)[] memory values) external view returns (uint) {
    return values[0](20, 22);
  }

  function storeMemoryFnPtr(function(uint, uint) external pure returns (uint)[] memory values,
                            function(uint, uint) external pure returns (uint) value) external pure {
    values[0] = value;
  }

  function loadMemoryFnPtrSuccess() external returns (uint) {
    function(uint, uint) external pure returns (uint)[] memory values =
      new function(uint, uint) external pure returns (uint)[](1);
    values[0] = this.add;
    return this.loadMemoryFnPtrHelper(values);
  }
}
