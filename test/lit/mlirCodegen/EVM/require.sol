// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
  error E(uint);
  function f(uint a, string memory msg) private {
    require(a > 42);
    require(a > 42, "");
    require(a > 42, "Foobar");
    require(a > 42, E(a));
    require(a > 42, msg);
  }
}

