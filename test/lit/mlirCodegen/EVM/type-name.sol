// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s

abstract contract A {
  function fa() public virtual;
}

interface I {
  function fi() external;
}

contract C {}

function name_contract() pure returns (string memory) {
  return type(C).name;
}

function name_abstract() pure returns (string memory) {
  return type(A).name;
}

function name_interface() pure returns (string memory) {
  return type(I).name;
}

contract Test {
  function getContractName() public pure returns (string memory) {
    return name_contract();
  }
  function getAbstractName() public pure returns (string memory) {
    return name_abstract();
  }
  function getInterfaceName() public pure returns (string memory) {
    return name_interface();
  }
}
