contract Receiver {
  receive() external payable {}
}

contract C {
  constructor() payable {}

  function s() public returns (bool) {
    Receiver r = new Receiver();
    return payable(r).send(0);
  }

  function t() public {
    Receiver r = new Receiver();
    payable(r).transfer(1 wei);
  }
}
