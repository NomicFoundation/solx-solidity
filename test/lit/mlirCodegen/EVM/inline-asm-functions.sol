    assembly {
      function g(x) -> y {
        y := mul(x, 2)
      }
      r := g(3)
    }
  }

  function h() public returns (uint256 r) {
    assembly {
      function g(x) -> y {
        y := mul(x, 3)
      }
      r := g(4)
    }
  }

  function k() public returns (uint256) {
    return ff(5);
  }
}
