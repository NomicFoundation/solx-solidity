function ff(uint256 x) pure returns (uint256 r) {
  assembly {
    function g(a) -> b {
      b := mul(a, 5)
    }
    r := g(x)
  }
}

contract C {
  constructor() {
    assembly {
      function cf(a) -> b {
        b := add(a, 1)
