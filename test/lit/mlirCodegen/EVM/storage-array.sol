// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
  // Non-packed arrays
  uint256[] arr256;
  uint256[4] staticArr256;

  // Packed arrays
  uint8[] arr8;
  uint8[4] staticArr8;
  uint256 afterStaticArr8;

  function rw() public {
    arr256.push(1);
    arr256.pop();
    staticArr256[0] = staticArr256[1];

    arr8.push(1);
    arr8.pop();
    staticArr8[0] = staticArr8[1];

    afterStaticArr8 = staticArr8[1];
  }
}

