  uint public i;
  uint[2][2] public i2;
  string public str;
  struct S {
    uint i;
    uint8 i8;
  }
  S public s;
  mapping(address => uint) public m;
  mapping(address => mapping(uint => uint)) public m2;
  mapping(C => uint) public mc;
  mapping(uint => C) public cm;

  uint public constant ci = 7;
}

