contract Magic {
  function callMsgSender() public returns (address) { return msgSender(); }
  function callAddr() public returns (address) { return addr(); }
  function callEncode(uint ui, uint8 ui8, int32 si32) public returns (bytes memory) { return encode(ui, ui8, si32); }
  function callDecode(bytes memory a) public returns (uint, uint8, int32) { return decode(a); }
  function callDecodeCalldata(bytes calldata a) public returns (uint, uint8, int32) { return decode_calldata(a); }
  function callEncodePacked(uint24 x, uint96 y, uint136 z) public returns (bytes memory) { return encode_packed(x, y, z); }
  function callEncodeAddr(address a) public returns (bytes memory) { return encode_addr(a); }
  function callDecodeAddr(bytes memory a) public returns (address) { return decode_addr(a); }
  function callDecodeAddrCalldata(bytes calldata a) public returns (address) { return decode_addr_calldata(a); }
  function callEncodePackedAddr(address a) public returns (bytes memory) { return encode_packed_addr(a); }
  function callRoundtripAddr(address a) public returns (address) { return roundtrip_addr(a); }
  function callRoundtripAddrTuple(address a, uint256 x) public returns (address, uint256) { return roundtrip_addr_tuple(a, x); }
  function callRoundtripAddrPayable(address a) public returns (address) { return roundtrip_addr_payable(a); }
  function callEncodeContract(CC c) public returns (bytes memory) { return encode_contract(c); }
  function callEncodePackedContract(CC c) public returns (bytes memory) { return encode_packed_contract(c); }
  function callDecodeContract(bytes memory data) public returns (CC) { return decode_contract(data); }
  function callDecodeContractCalldata(bytes calldata data) public returns (CC) { return decode_contract_calldata(data); }
  function callRoundtripContract(CC c) public returns (CC) { return roundtrip_contract(c); }
  function callDecodeContractTuple(bytes memory data) public returns (CC, uint256) { return decode_contract_tuple(data); }
  function callDecodeContractTupleCalldata(bytes calldata data) public returns (CC, uint256) { return decode_contract_tuple_calldata(data); }
  function callEncodePackedArraySigned(int8[] memory x) public returns (bytes memory) { return encode_packed_array_signed(x); }
  function callEncodePackedArrayUnsigned(uint8[] memory x) public returns (bytes memory) { return encode_packed_array_unsigned(x); }
  function callEncodePackedArrayEnum(E[] memory x) public returns (bytes memory) { return encode_packed_array_enum(x); }
  function callEncodePackedArrayBool(bool[] memory x) public returns (bytes memory) { return encode_packed_array_bool(x); }
  function callEncodePackedArrayAddress(address[] memory x) public returns (bytes memory) { return encode_packed_array_address(x); }
  function callEncodePackedContractAddress(CC[] memory x) public returns (bytes memory) { return encode_packed_contract_address(x); }
  function callEncodePackedCalldataArraySigned(int8[] calldata x) public returns (bytes memory) { return encode_packed_calldata_array_signed(x); }
  function callEncodePackedCalldataArrayUnsigned(uint8[] calldata x) public returns (bytes memory) { return encode_packed_calldata_array_unsigned(x); }
  function callEncodePackedCalldataArrayEnum(E[] calldata x) public returns (bytes memory) { return encode_packed_calldata_array_enum(x); }
  function callEncodePackedCalldataArrayBool(bool[] calldata x) public returns (bytes memory) { return encode_packed_calldata_array_bool(x); }
  function callEncodePackedCalldataArrayAddress(address[] calldata x) public returns (bytes memory) { return encode_packed_calldata_array_address(x); }
  function callEncodePackedCalldataArrayContract(CC[] calldata x) public returns (bytes memory) { return encode_packed_calldata_array_contract(x); }
  function callEncodeBool(bool x) public returns (bytes memory) { return encode_bool(x); }
  function callEncodeUint8(uint8 x) public returns (bytes memory) { return encode_uint8(x); }
  function callEncodeEnum(E x) public returns (bytes memory) { return encode_enum(x); }
  function callEncodeBytes5(bytes5 x) public returns (bytes memory) { return encode_bytes5(x); }
  function callEncodeArrayCalldataUnsigned(uint8[] calldata x) public returns (bytes memory) { return encode_array_calldata_unsigned(x); }
  function callEncodeArrayCalldataNestedUnsigned(uint8[][] calldata x) public returns (bytes memory) { return encode_array_calldata_nested_unsigned(x); }
  function callEncNested(uint256[2][3] calldata x) public returns (bytes memory) { return enc_nested(x); }
  function callEncodeArrayCalldataBool(bool[] calldata x) public returns (bytes memory) { return encode_array_calldata_bool(x); }
  function callEncodeArrayCalldataEnum(E[] calldata x) public returns (bytes memory) { return encode_array_calldata_enum(x); }
  function callEncodeArrayCalldataAddress(address[] calldata x) public returns (bytes memory) { return encode_array_calldata_address(x); }
  function callEncodeArrayCalldataContract(CC[] calldata x) public returns (bytes memory) { return encode_array_calldata_contract(x); }
  function callEncodePackedCalldataArrayBytes5(bytes5[] calldata x) public returns (bytes memory) { return encode_packed_calldata_array_bytes5(x); }
  function callEncodeArrayCalldataBytes5(bytes5[] calldata x) public returns (bytes memory) { return encode_array_calldata_bytes5(x); }
  function callEncodeSelector(bytes4 sel, uint256 x) public returns (bytes memory) { return encode_selector(sel, x); }
  function callEncodeFnptr(function(uint) external pure returns (uint) fp) public returns (bytes memory) { return encode_fnptr(fp); }
  function callEncodePackedFnptr(function(uint) external pure returns (uint) fp) public returns (bytes memory) { return encode_packed_fnptr(fp); }
  function callEncodePackedFnptrArray(function(uint) external pure returns (uint)[] memory arr) public returns (bytes memory) { return encode_packed_fnptr_array(arr); }
}

contract StorageBytes {
  bytes str;
  bytes str2;
  string sig;

  function ep_bytes_storage() public returns (bytes memory) {
    return abi.encodePacked(str);
  }

  function ep_bytes_concat_storage() public returns (bytes memory) {
    return abi.encodePacked(str, str2);
  }

  function ews_bytes_bytes_storage(bytes4 sel) public returns (bytes memory) {
    return abi.encodeWithSelector(sel, str);
  }

  function ewsig_runtime_storage(uint256 x) public returns (bytes memory) {
    return abi.encodeWithSignature(sig, x);
  }
}

