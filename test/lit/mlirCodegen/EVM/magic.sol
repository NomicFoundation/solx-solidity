  return abi.encodePacked(x);
}

function encode_packed_calldata_array_address(address[] calldata x) returns (bytes memory) {
  return abi.encodePacked(x);
}

function encode_packed_calldata_array_contract(CC[] calldata x) returns (bytes memory) {
  return abi.encodePacked(x);
}

function encode_bool(bool x) returns (bytes memory) {
  return abi.encode(x);
}

function encode_uint8(uint8 x) returns (bytes memory) {
  return abi.encode(x);
}

function encode_enum(E x) returns (bytes memory) {
  return abi.encode(x);
}

function encode_bytes5(bytes5 x) returns (bytes memory) {
  return abi.encode(x);
}

function encode_array_calldata_unsigned(uint8[] calldata x) returns (bytes memory) {
  return abi.encode(x);
}

function encode_array_calldata_nested_unsigned(uint8[][] calldata x) returns (bytes memory) {
  return abi.encode(x);
}

function enc_nested(uint256[2][3] calldata x) returns (bytes memory) {
  return abi.encode(x);
}

function encode_array_calldata_bool(bool[] calldata x) returns (bytes memory) {
  return abi.encode(x);
}

function encode_array_calldata_enum(E[] calldata x) returns (bytes memory) {
  return abi.encode(x);
}

function encode_array_calldata_address(address[] calldata x) returns (bytes memory) {
  return abi.encode(x);
}

function encode_array_calldata_contract(CC[] calldata x) returns (bytes memory) {
  return abi.encode(x);
}

function encode_packed_calldata_array_bytes5(bytes5[] calldata x) returns (bytes memory) {
  return abi.encodePacked(x);
}

function encode_array_calldata_bytes5(bytes5[] calldata x) returns (bytes memory) {
  return abi.encode(x);
}

function encode_selector(bytes4 sel, uint256 x) returns (bytes memory) {
  return abi.encodeWithSelector(sel, x);
}

function encode_fnptr(function(uint) external pure returns (uint) fp) pure returns (bytes memory) {
  return abi.encode(fp);
}

function encode_packed_fnptr(function(uint) external pure returns (uint) fp) pure returns (bytes memory) {
  return abi.encodePacked(fp);
}

function encode_packed_fnptr_array(function(uint) external pure returns (uint)[] memory arr) pure returns (bytes memory) {
  return abi.encodePacked(arr);
}

contract StorageBytes {
  bytes str;
  bytes str2;
  string sig;

  function ep_bytes_storage() public returns (bytes memory) {
    return abi.encodePacked(str);
  }

  function ep_bytes_concat_storage() public returns (bytes memory) {
    return abi.encodePacked(str, str2);
  }

  function ews_bytes_bytes_storage(bytes4 sel) public returns (bytes memory) {
    return abi.encodeWithSelector(sel, str);
  }

  function ewsig_runtime_storage(uint256 x) public returns (bytes memory) {
    return abi.encodeWithSignature(sig, x);
  }
}

