contract C {
  function a() external pure {}
  function b() external pure {}

  function encode(bool cond) external view returns (bytes memory, bytes4) {
    function() external fp = cond ? this.a : this.b;
    return (abi.encodeCall(fp, ()), fp.selector);
  }
}
