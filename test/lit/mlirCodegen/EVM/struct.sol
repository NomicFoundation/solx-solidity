// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s

struct S {
  uint256 ui;
  uint256[3] ui_1d;
}

function ui(S memory s) returns (uint256) {
  return s.ui + s.ui_1d[2];
}

function malloc() {
  S memory s;
}

struct DynS {
  uint16[] m;
}

function cd_dyn_member(DynS calldata s) returns (uint16) {
  return s.m[0];
}

