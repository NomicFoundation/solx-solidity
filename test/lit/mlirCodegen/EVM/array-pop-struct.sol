// RUN: solc --mlir-action=print-std-mlir --mlir-target=evm --mmlir --mlir-print-debuginfo %s | FileCheck %s

contract C {
    struct Scalars {
        uint256 x;
        uint256 y;
        address addr;
    }

    struct Packed {
        uint256 val;
        bool    flag;
        uint8   tag;
    }

    struct WithFixedArr {
        uint256    x;
        uint256[3] arr;
        uint256    y;
    }

    struct Inner {
        uint256 v;
        bool    active;
    }

    struct WithNested {
        uint256 a;
        Inner   inner;
        uint256 b;
    }

    Scalars[]      scalarsArr;
    Packed[]       packedArr;
    WithFixedArr[] fixedArrArr;
    WithNested[]   nestedArr;

    function popScalars()   public { scalarsArr.pop(); }
    function popPacked()    public { packedArr.pop(); }
    function popFixedArr()  public { fixedArrArr.pop(); }
    function popNested()    public { nestedArr.pop(); }
}
