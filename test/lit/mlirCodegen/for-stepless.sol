// RUN: solc --mlir-action=print-init --mmlir --mlir-print-debuginfo %s | FileCheck %s

function infinite() {
  for (;;) {
    break;
  }
}

function no_step(uint n) {
  uint i = 0;
  for (; i < n;) {
    i += 1;
  }
}

