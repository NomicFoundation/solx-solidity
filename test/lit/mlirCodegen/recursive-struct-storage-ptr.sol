// RUN: solc --mlir-action=print-init --mmlir --mlir-print-debuginfo %s | FileCheck %s
pragma solidity ^0.8.0;

contract C {
  struct S {
    uint256 value;
    S[] children;
  }

  S root;

  function f() public returns (uint256) {
    S storage p = root;
    p.value = 42;
    return p.value;
  }
}

